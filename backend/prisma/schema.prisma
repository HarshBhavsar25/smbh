generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum FeeStatus {
  PAID
  PARTIAL
  PENDING
  REJECTED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VacationStatus {
  IN_HOSTEL
  ON_VACATION
  RETURNED
}

enum RoomType {
  TWO_SHARING
  THREE_SHARING
  FIVE_SHARING
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  role          Role     @default(STUDENT)
  profileImage  String?
  fcmToken      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  studentProfile StudentProfile?
  posts          Post[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
}

model StudentProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  fullName      String
  photo         String?
  mobile        String
  collegeName   String
  course        String
  parentName    String
  parentContact String
  address       String
  admissionDate DateTime @default(now())
  roomId        String?
  room          Room?    @relation(fields: [roomId], references: [id])
  feeStatus     FeeStatus @default(PENDING)
  
  dob             String?
  bloodGroup      String?
  academicYear    String?
  guardianName2   String?
  guardianContact2 String?
  vehicleNo       String?
  locationInRoom  String?
  yearOfStudy     String?
  yearOfStudyOther String?
  
  securityDeposit Float    @default(0)
  refundAmount    Float    @default(0)
  balanceFee    Float    @default(0)
  hasLeft         Boolean  @default(false)
  leftDate        DateTime?
  
  aadhaarUrl    String?
  collegeIdUrl  String?
  panUrl        String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  feePayments   FeePayment[]
  complaints    Complaint[]
  votes         ComplaintVote[]
  comments      ComplaintComment[]
  vacations     VacationRequest[]
  leaveRequests LeaveRequest[]
  attendanceRecords AttendanceRecord[]
}

model Room {
  id               String   @id @default(uuid())
  roomNumber       String   @unique
  capacity         Int
  currentOccupancy Int      @default(0)
  type             RoomType
  students         StudentProfile[]
  
  locations        String[] @default([])
  cupboard         Boolean  @default(false)
  bed              Boolean  @default(false)
  geyser           Boolean  @default(false)
  electricBoard    Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FeePayment {
  id          String   @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  amount      Float
  status      FeeStatus
  paymentDate DateTime @default(now())
  receiptUrl  String?
  utr         String?
  paymentType String   @default("HOSTEL_FEE")
  
  hostelFee   Float    @default(5000)
  lightBill   Float    @default(300)
  laundry     Float    @default(0)
  balanceFee  Float    @default(0)
  sendingAccountName String?
  
  hostelFeeMonth  String?
  lightBillMonth  String?
  laundryMonth    String?
  balanceFeeMonth String?
  paymentMode     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Complaint {
  id          String   @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  title       String
  description String
  image       String?
  status      ComplaintStatus @default(OPEN)
  votesCount    Int      @default(0)
  adminResponse String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  votes       ComplaintVote[]
  comments    ComplaintComment[]
}

model ComplaintVote {
  id          String   @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  type        Boolean  // true for agree, false for disagree
  createdAt   DateTime @default(now())
  
  @@unique([complaintId, studentId])
}

model ComplaintComment {
  id          String   @id @default(uuid())
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  text        String
  createdAt   DateTime @default(now())
}

model GalleryAlbum {
  id          String   @id @default(uuid())
  title       String
  description String?
  media       GalleryMedia[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryMedia {
  id          String   @id @default(uuid())
  albumId     String
  album       GalleryAlbum @relation(fields: [albumId], references: [id])
  url         String
  type        String   // "IMAGE" or "VIDEO"
  createdAt   DateTime @default(now())
}

model Post {
  id          String   @id @default(uuid())
  type        String   // "BLOG" or "NOTICE"
  title       String
  content     String
  media       String?
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VacationRequest {
  id             String   @id @default(uuid())
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id])
  reason         String
  departureDate  DateTime
  returnDate     DateTime?
  status         VacationStatus @default(ON_VACATION)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  details     String?
  createdAt   DateTime @default(now())
}

model LeaveRequest {
  id          String         @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  imageUrl    String
  status      String         @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Rule {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id          String             @id @default(uuid())
  date        DateTime           @default(now())
  takenBy     String?
  records     AttendanceRecord[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model AttendanceRecord {
  id           String         @id @default(uuid())
  attendanceId String
  attendance   Attendance     @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String         // "PRESENT" or "ABSENT"
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([attendanceId, studentId])
}

model ApplicationForm {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Student Info - Personal Details
  fullName      String
  mobile        String
  dob           String
  gender        String
  aadhaarNumber String
  panNumber     String?
  email         String
  bloodGroup    String
  photoUrl      String

  // Student Info - Academic Details
  collegeName   String
  course        String
  year          String
  rollNumber    String
  academicYear  String

  // Student Info - Hostel Details
  roomNumber    String
  bedNumber     String?
  admissionDate String
  joiningDate   String
  expectedStay  String

  // Student Info - Documents
  aadhaarCardUrl      String
  panCardUrl          String
  collegeIdUrl        String?
  admissionReceiptUrl String?

  // Parent / Guardian Info
  parentName      String
  fatherName      String
  motherName      String
  parentOccupation String
  parentMobile    String
  parentAltMobile String?
  presentAddress  String
  city            String
  state           String
  pinCode         String
  parentAadhaar   String
  parentPan       String

  // Medical Info
  hasChronicIllness       Boolean
  illnessDescription      String?
  requiresUrgentAttention String?
  allergies               String?
  familyDoctorName        String?
  familyDoctorContact     String?
  medicalBloodGroup       String

  // Emergency Contact
  emergencyName         String
  emergencyRelationship String
  emergencyMobile       String
  emergencyAltMobile    String?

  // Hostel Agreement Checkboxes
  agreeHostelRules          Boolean
  agreeFeeTerms             Boolean
  agreeLockIn               Boolean
  agreeSecurityRefund       Boolean
  agreeDisciplinary         Boolean
  agreeDamageRecovery       Boolean
  agreeAlcoholProhibition   Boolean
  agreeEntryExitRules       Boolean
  studentSignatureUrl       String
  agreementDate             String
  agreementPlace            String

  // Room Amenities
  amenityCeilingFan           Boolean
  amenityLocker               Boolean
  amenityBed                  Boolean
  amenityMattress             Boolean
  amenityTubeLight            Boolean
  amenityWaterGeyser          Boolean
  existingDamageNotes         String?
  roomConditionRemarks        String?
  amenityConfirmation         Boolean
  amenityStudentSignatureUrl String
  amenityDate                 String

  // Parent Acknowledgement
  ackParentName         String
  ackParentMobile       String
  ackParentAddress      String
  ackParentConfirmation Boolean
  ackParentSignatureUrl String
  ackParentDate         String
  ackParentPlace        String
}

model SystemSetting {
  key   String @id
  value String
}
